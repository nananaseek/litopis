# MongoDB (якщо не задано — backend використовує контейнер mongodb з Docker)
# Для зовнішньої БД вставте повне посилання, наприклад:
# MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGODB_URL=mongodb://user:pass@host:27017/
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=litopis

# JWT
JWT_SECRET_KEY=change-me-generate-a-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (додайте https://your-domain.com для продакшену)
CORS_ORIGINS=["https://example.com","http://localhost:3000","http://localhost:5173"]

# SSL / nginx-proxy + acme-companion
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# Debug
DEBUG=false
